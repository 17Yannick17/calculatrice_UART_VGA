module calculator_vga_top (
	CLOCK_50,
	KEY,
	UART_RX,
	VGA_R,
	VGA_G,
	VGA_B,
	VGA_HS,
	VGA_VS);
input 	CLOCK_50;
input 	[1:0] KEY;
input 	UART_RX;
output 	[3:0] VGA_R;
output 	[3:0] VGA_G;
output 	[3:0] VGA_B;
output 	VGA_HS;
output 	VGA_VS;

